# oop in pYthon
class student:  # make a respecttable class
    def __init__(self, age, name, rollno, marks):  # constructor
        self.age = age
        self.name = name
        self.rollno = rollno
        self.marks = marks

    def display(self):  # method to display student details
        print("Age:", self.age)
        print("Name:", self.name)
        print("Roll No:", self.rollno)
        print("Marks:", self.marks)

# Create student objects
s1 = student(20, "john", 101, 76)
s2 = student(21, "doe", 102, 77)
s1.display()
s2.display()
